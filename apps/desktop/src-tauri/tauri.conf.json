{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dev Project Organizer",
  "version": "0.1.0",
  "identifier": "com.devprojectorganizer.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Dev Project Organizer",
        "width": 1280,
        "height": 800,
        "center": true,
        "visible": true,
        "fullscreen": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "sql": {
      "preloads": ["sqlite:dev-organizer.db"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
